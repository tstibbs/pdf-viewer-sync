{
	"name": "@tstibbs/pdf-viewer-sync-ui",
	"version": "0.0.1",
	"private": true,
	"devEngines": {
		"runtime": {
			"name": "node",
			"version": "22",
			"onFail": "error"
		},
		"packageManager": {
			"name": "pnpm",
			"version": ">=11.7",
			"onFail": "error"
		}
	},
	"main": "index.js",
	"type": "module",
	"devDependencies": {
		"@tstibbs/cloud-core-utils": "github:tstibbs/cloud-core#path:/aws/utils",
		"copy-webpack-plugin": "^14.0.0",
		"css-loader": "^7.1.4",
		"html-webpack-plugin": "^5.6.7",
		"http-server": "^14.1.1",
		"license-webpack-plugin": "^4.0.2",
		"mini-css-extract-plugin": "^2.10.2",
		"webpack": "^5.108.4",
		"webpack-cli": "^7.2.1",
		"webpack-dev-server": "^6.0.0"
	},
	"dependencies": {
		"@tstibbs/cloud-core-ui": "github:tstibbs/cloud-core#path:/ui",
		"axios": "^1.18.1",
		"memfs": "^4.57.8",
		"pdfjs-dist": "3.11.174",
		"qrcode": "^1.5.4",
		"toastr": "^2.1.4",
		"ua-parser-js": "^2.0.10"
	},
	"scripts": {
		"_pre": "rm -rf dist",
		"build": "pnpm run _pre && webpack",
		"deploy": "pnpm run build && ./deploy.sh",
		"serve": "http-server dist -c-1",
		"dev": "pnpm run _pre && webpack serve",
		"download-deps": "node build/download-deps.js"
	}
}
